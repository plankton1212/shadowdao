# Sepolia RPC URL (for contract deployment and frontend)
SEPOLIA_RPC_URL="https://ethereum-sepolia-rpc.publicnode.com"

# Deployer private key (for contract deployment via Hardhat - DO NOT COMMIT)
PRIVATE_KEY=""

# ─── Vercel Environment Variables (set in Vercel dashboard, NOT .env) ─────────
# These are server-side only — never exposed to the browser.
#
# Pinata IPFS — for discussion comments (visible to all users via public IPFS)
# Get free key at: https://app.pinata.cloud → API Keys → New Key → pinFileToIPFS + pinJSONToIPFS
# PINATA_JWT=your_jwt_here
#
# Optional: use your own Pinata dedicated gateway for faster loads
# PINATA_GATEWAY=https://gateway.pinata.cloud

# Second account for multi-account tests
PRIVATE_KEY_2=""

